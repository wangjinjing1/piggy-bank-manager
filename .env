SPRING_DATASOURCE_URL=jdbc:mysql://mysql.top:port/piggy_bank?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&createDatabaseIfNotExist=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root

# 容器和 JVM 时区；日志、启动时间和定时任务会按这个时区显示/执行。
TZ=Asia/Shanghai
JAVA_TOOL_OPTIONS=-Duser.timezone=Asia/Shanghai

SPRING_MAIL_HOST=smtp.qq.com
SPRING_MAIL_PORT=465
SPRING_MAIL_PROTOCOL=smtps
SPRING_MAIL_USERNAME=邮箱账户
SPRING_MAIL_PASSWORD=邮箱密码
SPRING_MAIL_SSL_ENABLE=true
SPRING_MAIL_STARTTLS_ENABLE=false

APP_ENCRYPTION_KEY=至少32字符更改此秘密密钥
APP_TOKEN_SECRET=至少32字符更改此秘密密钥
APP_PUBLIC_BASE_URL=项目访问地址
APP_REMINDER_CRON=0 0 9 * * ?
APP_STARTUP_MAIL_ENABLED=false
APP_STARTUP_MAIL_TO=启动通知邮箱
APP_SECURITY_MAX_REQUESTS_PER_IP_PER_DAY=200

APP_ADMIN_USERNAME=首次启动默认用户
APP_ADMIN_PASSWORD=首次启动默认密码
APP_ADMIN_EMAIL=首次启动默认用户邮箱
